{
  "name": "greenlife-food",
  "version": "1.0.0",
  "description": "GreenLife Food E-Commerce Platform - Healthy food delivery",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev -w frontend",
    "dev:frontend": "npm run dev -w frontend",
    "local": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local.ps1",
    "build": "npm run build -w frontend",
    "start": "docker-compose up -d",
    "stop": "docker-compose down",
    "lint": "npm run lint -w frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
