# Sao chép / map vào Railway → Service Backend → Variables
# PostgreSQL: thêm plugin Postgres; Railway thường cung cấp PGHOST, PGPORT, PGDATABASE, PGUSER, PGPASSWORD

SPRING_PROFILES_ACTIVE=prod

# JDBC (application-prod.yml)
PGHOST=${{Postgres.PGHOST}}
PGPORT=${{Postgres.PGPORT}}
PGDATABASE=${{Postgres.PGDATABASE}}
# Map user/password — nếu template dùng PGUSER thì đặt DB_USER trùng giá trị hoặc reference biến Railway
DB_USER=${{Postgres.PGUSER}}
DB_PASSWORD=${{Postgres.PGPASSWORD}}

# JWT — bắt buộc đổi; chuỗi dài ngẫu nhiên (≥ 32 ký tự khuyến nghị)
JWT_SECRET=thay-bang-chuoi-bi-mat-rat-dai

# CORS: URL frontend public (có thể nhiều origin, cách nhau dấu phẩy)
CORS_ORIGINS=https://your-frontend.up.railway.app

# Railway gán PORT tự động; Spring dùng ${PORT} trong application-prod.yml (mặc định 5000)
