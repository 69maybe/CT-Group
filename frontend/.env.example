# Đích rewrite của Next: /api/* → backend (trình duyệt gọi cùng origin :3000/api)
NEXT_PUBLIC_API_URL=http://127.0.0.1:5000
# Tuỳ chọn alias cho next.config (mặc định dùng NEXT_PUBLIC_API_URL)
# BACKEND_URL=http://127.0.0.1:5000
# SSR gọi trực tiếp backend (hiếm khi cần)
# INTERNAL_API_URL=http://127.0.0.1:5000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
