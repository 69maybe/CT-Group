# Sao chép các biến sau vào Railway → Service **Frontend** → Variables
# (Đặt trên service Next.js, KHÔNG chỉ backend — thiếu là lỗi 502 "Backend unreachable".)
# URL: https://... không dấu / cuối

# Bắt buộc: URL đầy đủ có https:// (copy domain từ Networking backend)
BACKEND_URL=https://your-backend.up.railway.app
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
# Nếu chỉ dán hostname không scheme, code sẽ tự thêm https:// — nên vẫn ghi rõ https:// cho chắc.

# URL public của chính site Next.js (SEO, link tuyệt đối nếu có dùng)
NEXT_PUBLIC_SITE_URL=https://your-frontend.up.railway.app

# Tuỳ chọn: SSR gọi API (ít dùng khi đã có BACKEND_URL)
# INTERNAL_API_URL=https://your-backend.up.railway.app
